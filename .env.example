# llm-localfirst configuration — copy to `.env` and edit. Every value here is a
# placeholder; the real `.env` is gitignored. Settings are read with the `LF_` prefix.

# --- Local model (OpenAI-compatible: Ollama / vLLM / LM Studio) ---
LF_LOCAL_BASE_URL=http://localhost:11434/v1
LF_LOCAL_MODEL_ID=qwen2.5:7b
# Local servers usually ignore the key; leave the default unless yours needs one.
LF_LOCAL_API_KEY_ENV=LF_LOCAL_API_KEY

# --- Routing behaviour ---
LF_DEFAULT_KIND=auto
LF_FALLBACK_MODEL=haiku
LF_REASON_MODEL=haiku
# Keep this true: sensitive calls fail closed instead of ever falling back to cloud.
LF_SENSITIVE_FAIL_CLOSED=true
LF_PROBE_TTL=30.0

# --- Cloud (optional; only needed to actually run cloud-routed calls) ---
# Names of the env vars holding your keys — NOT the keys themselves.
LF_ANTHROPIC_API_KEY_ENV=ANTHROPIC_API_KEY
LF_OPENAI_API_KEY_ENV=OPENAI_API_KEY
LF_OPENAI_BASE_URL=https://api.openai.com/v1
LF_OPENAI_MODEL_ID=gpt-4o-mini

# --- The actual cloud keys (do NOT commit real values; keep them in your .env) ---
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
OPENAI_API_KEY=sk-REPLACE_ME
